{
    "preset": "laravel",
    "rules": {
        "binary_operator_spaces": {
            "operators": {
                "=>": "align_single_space_minimal"
            }
        },
        "not_operator_with_successor_space": false,
        "concat_space": {
            "spacing": "none"
        },
        "phpdoc_align": false
    }
}
