{
    "name": "src83/laravel-api-response",
    "description": "Structured REST API responses for Laravel with exception handling, localization, logging, and pagination",
    "keywords": ["laravel", "api", "response", "json", "exception", "handler", "localization", "pagination"],
    "homepage": "https://github.com/src83/laravel-api-response",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Roman Staroseltsev",
            "email": "r.staroseltsev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^9.0|^10.0|^11.0",
        "illuminate/support": "^9.0|^10.0|^11.0",
        "illuminate/log": "^9.0|^10.0|^11.0",
        "illuminate/pagination": "^9.0|^10.0|^11.0",
        "illuminate/validation": "^9.0|^10.0|^11.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Src83\\LaravelApiResponse\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Src83\\LaravelApiResponse\\Tests\\": "tests/"
        }
    },
    "support": {
        "source": "https://github.com/src83/laravel-api-response",
        "issues": "https://github.com/src83/laravel-api-response/issues"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Src83\\LaravelApiResponse\\ApiResponseServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit -c tests/phpunit.xml",
        "lint": "vendor/bin/pint --test",
        "lint-fix": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse -c phpstan.neon --no-progress --no-interaction"
    },
    "config": {
        "sort-packages": true,
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
