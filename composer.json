{
    "name": "src83/laravel-api-response",
    "description": "Unified JSON API response system for Laravel: structured responses, exception handling, localization, logging, and pagination.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "api", "response", "json", "exception", "handler", "localization", "pagination"],
    "authors": [
        {
            "name": "Roman Staroseltsev",
            "email": "r.staroseltsev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^9.0|^10.0|^11.0",
        "illuminate/support": "^9.0|^10.0|^11.0",
        "illuminate/log": "^9.0|^10.0|^11.0",
        "illuminate/pagination": "^9.0|^10.0|^11.0",
        "illuminate/validation": "^9.0|^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Src83\\LaravelApiResponse\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Src83\\LaravelApiResponse\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Src83\\LaravelApiResponse\\ApiResponseServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
